        "node": ">=18.0.0"
    },
    "dependencies": {
        "@whiskeysockets/baileys": "^7.0.0-rc11",
        "dotenv": "^16.6.1",
        "express": "^4.22.2",
        "pino": "^9.14.0",
        "qrcode": "^1.5.4",
        "qrcode-terminal": "^0.12.0"
    }
