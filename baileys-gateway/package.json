{
    "name": "masjid-baileys-gateway",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Baileys WhatsApp gateway khusus Aplikasi Manajemen Masjid",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "pm2:start": "pm2 start ecosystem.config.cjs",
        "pm2:restart": "pm2 restart masjid-baileys-gateway",
        "pm2:stop": "pm2 stop masjid-baileys-gateway",
        "pm2:logs": "pm2 logs masjid-baileys-gateway",
